{
  "name": "@civic/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build -p tsconfig.build.json",
    "start:dev": "ts-node --project tsconfig.json src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
